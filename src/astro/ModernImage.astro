---
import { DEFAULT_QUALITY, QUALITY_RANGE, WIDTH_RANGE } from "../lib/constants";

export interface Props {
  image: { id?: string; src?: string; alt?: string; meta?: { storageKey?: string } };
  widths?: number[];
  sizes?: string;
  class?: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync" | "auto";
  preload?: boolean;
  formatQuality?: number;
}

const {
  image,
  widths = [480, 640, 960, 1200],
  sizes = "100vw",
  class: className,
  loading = "lazy",
  decoding = "async",
  preload = false,
  formatQuality = DEFAULT_QUALITY,
} = Astro.props;

const isExternal = typeof image.src === "string" && (image.src.startsWith("http://") || image.src.startsWith("https://"));

let storageKey = "";
if (!isExternal) {
  storageKey = image.meta?.storageKey || image.id || "";
  if (!storageKey && image.src) {
    const m = image.src.match(/\/_emdash\/(?:api\/)?media\/file\/([^?]+)/);
    try {
      storageKey = m?.[1] ? decodeURIComponent(m[1]) : "";
    } catch {
      storageKey = m?.[1] || "";
    }
  }
}

const showPicture = !isExternal && storageKey.length > 0;
const imgAlt = image.alt || "";
const normalizedQuality = Math.max(QUALITY_RANGE.min, Math.min(QUALITY_RANGE.max, Number(formatQuality) || DEFAULT_QUALITY));
const requestedWidths = [...new Set(widths)]
  .map((width) => Number(width))
  .filter((width) => Number.isFinite(width))
  .map((width) => Math.max(WIDTH_RANGE.min, Math.min(WIDTH_RANGE.max, Math.round(width))))
  .sort((a, b) => a - b);
const normalizedWidths = requestedWidths.length > 0 ? requestedWidths : [960];
let avifSrcset = "";
let webpSrcset = "";
let preloadHref = "";
let preloadSrcset = "";

if (showPicture) {
  const base = `/_emdash/api/media/file/${encodeURIComponent(storageKey)}`;
  avifSrcset = normalizedWidths.map((w) => `${base}?format=avif&w=${w}&q=${normalizedQuality} ${w}w`).join(", ");
  webpSrcset = normalizedWidths.map((w) => `${base}?format=webp&w=${w}&q=${normalizedQuality} ${w}w`).join(", ");
  const preloadWidth = normalizedWidths.find((width) => width >= 960) ?? normalizedWidths.at(-1) ?? 960;
  preloadHref = `${base}?format=avif&w=${preloadWidth}&q=${normalizedQuality}`;
  preloadSrcset = avifSrcset;
}
---

{
  preload && showPicture && (
    <link rel="preload" as="image" href={preloadHref} imagesrcset={preloadSrcset} imagesizes={sizes} type="image/avif" />
  )
}
{
  showPicture ? (
    <picture>
      <source srcset={avifSrcset} sizes={sizes} type="image/avif" />
      <source srcset={webpSrcset} sizes={sizes} type="image/webp" />
      <img src={`/_emdash/api/media/file/${encodeURIComponent(storageKey)}`} alt={imgAlt} loading={loading} decoding={decoding} class={className} />
    </picture>
  ) : (
    <img src={image.src || ""} alt={imgAlt} loading={loading} decoding={decoding} class={className} />
  )
}
