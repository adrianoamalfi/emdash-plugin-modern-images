---
import { SUPPORTED_FORMATS, WIDTH_CANDIDATES, DEFAULT_QUALITY, FORMAT_MAP } from "../lib/constants";

export interface Props {
  image: { id?: string; src?: string; alt?: string; meta?: { storageKey?: string } };
  widths?: number[];
  sizes?: string;
  class?: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync" | "auto";
  preload?: boolean;
  formatQuality?: number;
}

const {
  image,
  widths = [480, 640, 960, 1200],
  sizes = "100vw",
  class: className,
  loading = "lazy",
  decoding = "async",
  preload = false,
  formatQuality = DEFAULT_QUALITY,
} = Astro.props;

const isExternal = typeof image.src === "string" && (image.src.startsWith("http://") || image.src.startsWith("https://"));

let storageKey = "";
if (!isExternal) {
  storageKey = image.meta?.storageKey || image.id || "";
  if (!storageKey && image.src) {
    const m = image.src.match(/\/_emdash\/(?:api\/)?media\/file\/([^?]+)/);
    storageKey = m?.[1] || "";
  }
}

const showPicture = !isExternal && storageKey.length > 0;
const imgAlt = image.alt || "";
let avifSrcset = "";
let webpSrcset = "";
let preloadHref = "";
let preloadSrcset = "";

if (showPicture) {
  const base = `/_emdash/api/media/file/${storageKey}`;
  avifSrcset = widths.map((w) => `${base}?format=avif&w=${w}&q=${formatQuality} ${w}w`).join(", ");
  webpSrcset = widths.map((w) => `${base}?format=webp&w=${w}&q=${formatQuality} ${w}w`).join(", ");
  preloadHref = `${base}?format=avif&w=960&q=${formatQuality}`;
  preloadSrcset = avifSrcset;
}
---

{
  preload && showPicture && (
    <link rel="preload" as="image" href={preloadHref} imagesrcset={preloadSrcset} imagesizes={sizes} type="image/avif" />
  )
}
{
  showPicture ? (
    <picture>
      <source srcset={avifSrcset} sizes={sizes} type="image/avif" />
      <source srcset={webpSrcset} sizes={sizes} type="image/webp" />
      <img src={`/_emdash/api/media/file/${storageKey}`} alt={imgAlt} loading={loading} decoding={decoding} class={className} />
    </picture>
  ) : (
    <img src={image.src || ""} alt={imgAlt} />
  )
}
