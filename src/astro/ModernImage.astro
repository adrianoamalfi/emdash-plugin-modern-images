---
import { SUPPORTED_FORMATS, WIDTH_CANDIDATES, DEFAULT_QUALITY, FORMAT_MAP } from "../lib/constants";

export interface Props {
  image: { src?: string; alt?: string };
  widths?: number[];
  sizes?: string;
  class?: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync" | "auto";
  preload?: boolean;
  formatQuality?: number;
}

const {
  image,
  widths = [480, 640, 960, 1200],
  sizes = "100vw",
  class: className,
  loading = "lazy",
  decoding = "async",
  preload = false,
  formatQuality = DEFAULT_QUALITY,
} = Astro.props;

const isExternal = image.src?.startsWith("http://") || image.src?.startsWith("https://");
const mediaMatch = image.src?.match(/\/_emdash\/(?:api\/)?media\/file\/([^?]+)/);
const storageKey = isExternal ? null : (mediaMatch?.[1] || null);

if (isExternal || !storageKey) {
  <img src={image.src || ""} alt={image.alt || ""} />
} else {
  const mediaBase = `/_emdash/api/media/file/${storageKey}`;
  const srcset = (fmt: string) =>
    widths.map((w) => `${mediaBase}?format=${fmt}&w=${w}&q=${formatQuality} ${w}w`).join(",\n");

  const formats = ["avif", "webp"] as const;

  {preload && (
    <link
      rel="preload"
      as="image"
      href={`${mediaBase}?format=avif&w=960&q=${formatQuality}`}
      imagesrcset={srcset("avif")}
      imagesizes={sizes}
      type="image/avif"
    />
  )}
  <picture>
    {formats.map((fmt) => (
      <source srcset={srcset(fmt)} sizes={sizes} type={FORMAT_MAP[fmt].mime} />
    ))}
    <img src={mediaBase} alt={image.alt || ""} loading={loading} decoding={decoding} class={className} />
  </picture>
}
